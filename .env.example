ELASTICSEARCH_URL=https://your-elasticsearch-host:9200
ELASTICSEARCH_USERNAME=your_username
ELASTICSEARCH_PASSWORD=your_password
ELASTICSEARCH_VERIFY_CERTS=false

KIBANA_URL=https://your-kibana-host:5601
KIBANA_USERNAME=your_username
KIBANA_PASSWORD=your_password
KIBANA_VERIFY_CERTS=false

MAX_NEW_ALERTS_PER_RUN=0
FETCH_BATCH_SIZE=25
POLL_INTERVAL_SECONDS=60

ALERT_INDEX_PATTERN=.alerts-security.alerts-default

OLLAMA_URL=http://your-ollama-host:11434/api/generate
OLLAMA_MODEL=qwen2.5:3b